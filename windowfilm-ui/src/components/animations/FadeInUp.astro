---
// FadeInUp.astro
// Animation wrapper: reveals its content (rises + fades in) when it
// enters the viewport on scroll. Respects "reduce motion".
//
// HOW TO USE: wrap anything.
//   <FadeInUp><h2>Hello</h2></FadeInUp>
//   <FadeInUp delay={150}>...</FadeInUp>   (delay in milliseconds)

interface Props { delay?: number; }
const { delay = 0 } = Astro.props;
---

<div class="fade-in-up" style={`--fade-delay:${delay}ms`}>
  <slot />
</div>

<style>
  .fade-in-up {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.7s ease-out, transform 0.7s ease-out;
    transition-delay: var(--fade-delay, 0ms);
  }
  .fade-in-up.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
  @media (prefers-reduced-motion: reduce) {
    .fade-in-up { opacity: 1; transform: none; transition: none; }
  }
</style>

<script>
  // Watch the elements and reveal them when they enter the viewport.
  const els = document.querySelectorAll('.fade-in-up');
  const io = new IntersectionObserver((entries) => {
    entries.forEach((e) => {
      if (e.isIntersecting) {
        e.target.classList.add('is-visible');
        io.unobserve(e.target);
      }
    });
  }, { threshold: 0.15 });
  els.forEach((el) => io.observe(el));
</script>
