---
// WordStagger.astro
// Reveals a heading word-by-word on load (from the Hero).
// Each word rises + fades in, staggered 80ms base + 110ms per word.
// Pure CSS transitions + a tiny vanilla JS trigger.
//
// HOW TO USE:
//   <WordStagger text="Philadelphia's glass, transformed." as="h1"
//     class="font-display text-5xl font-bold text-white" />
//   `as` is the tag to render (h1/h2/p). `class` styles the whole line.

interface Props {
  text: string;
  as?: string;
  class?: string;
}
const { text, as: Tag = 'h1', class: cls = '' } = Astro.props;
const words = text.split(' ');
---

<Tag class={cls}>
  {words.map((w, i) => (
    <span class="hero-word" style={`display:inline-block`}>{w}{i < words.length - 1 ? '\u00A0' : ''}</span>
  ))}
</Tag>

<style is:global>
  .hero-word {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }
  .hero-word.visible { opacity: 1; transform: translateY(0); }
  @media (prefers-reduced-motion: reduce) {
    .hero-word { opacity: 1; transform: none; transition: none; }
  }
</style>

<script>
  const words = document.querySelectorAll('.hero-word');
  words.forEach((word, i) => {
    setTimeout(() => word.classList.add('visible'), 80 + i * 110);
  });
</script>
