---
// VideoBand.astro
// Full-width band with a looping background video and overlaid text.
// No JS — autoplay muted loop playsinline.
//
// HOW TO USE:
//   <VideoBand heading="See the film go on" video="https://.../clip.mp4" />

interface Props {
  heading?: string;
  subtitle?: string;
  video?: string;
  ctaText?: string;
  ctaHref?: string;
}
const {
  heading = 'See the difference film makes',
  subtitle = 'Professional installation, backed by warranty.',
  video = 'https://res.cloudinary.com/deunehrew/video/upload/f_auto,q_auto,vc_auto/v1781723919/film_install_lam4dj.mov',
  ctaText = 'Get a free quote',
  ctaHref = '/contact/',
} = Astro.props;
---

<section class="relative isolate flex min-h-[360px] items-center justify-center overflow-hidden text-center">
  <video class="absolute inset-0 -z-10 h-full w-full object-cover" autoplay muted loop playsinline>
    <source src={video} type="video/mp4" />
  </video>
  <div class="absolute inset-0 -z-10 bg-ink/70"></div>
  <div class="mx-auto max-w-2xl px-6 py-16">
    <h2 class="font-display text-3xl font-bold text-white sm:text-4xl">{heading}</h2>
    {subtitle && <p class="mt-3 text-white/75">{subtitle}</p>}
    {ctaText && <a href={ctaHref} class="mt-6 inline-block rounded-full bg-brand px-7 py-3 font-semibold text-white transition hover:bg-brand-dark">{ctaText}</a>}
  </div>
</section>
