---
// ElementShowcase.astro
// Wraps each catalog element: shows the live render, the import name,
// a usage note, and the code to copy & paste.
//
// Props:
//   title    -> visible name of the element (e.g. "Logo Animation")
//   importAs -> how it's imported (e.g. "LogoAnimation")
//   file     -> file path (e.g. "components/LogoAnimation.astro")
//   usage    -> short note: where it goes / what to change
//   code     -> the code block the team copies & pastes
// Default slot -> the live render of the element.

interface Props {
  title: string;
  importAs: string;
  file: string;
  usage: string;
  code: string;
}

const { title, importAs, file, usage, code } = Astro.props;
const importLine = `import ${importAs} from '../components/${file.replace('components/', '')}';`;
---

<section class="mb-16 scroll-mt-24" id={importAs.toLowerCase()}>
  <header class="mb-4 flex flex-wrap items-baseline gap-x-3 gap-y-1 border-b border-white/10 pb-3">
    <h2 class="font-display text-2xl text-white">{title}</h2>
    <code class="rounded bg-brand/15 px-2 py-0.5 font-mono text-sm text-brand-light">{`<${importAs} />`}</code>
    <span class="font-mono text-xs text-white/40">src/{file}</span>
  </header>

  <p class="mb-5 max-w-2xl text-sm leading-relaxed text-white/60">{usage}</p>

  <!-- LIVE PREVIEW -->
  <div class="mb-5 overflow-hidden rounded-xl border border-white/10 bg-ink">
    <div class="flex items-center gap-2 border-b border-white/10 bg-white/5 px-4 py-2">
      <span class="h-2.5 w-2.5 rounded-full bg-white/20"></span>
      <span class="h-2.5 w-2.5 rounded-full bg-white/20"></span>
      <span class="h-2.5 w-2.5 rounded-full bg-white/20"></span>
      <span class="ml-2 text-xs text-white/40">Preview</span>
    </div>
    <div class="p-0">
      <slot />
    </div>
  </div>

  <!-- IMPORT BLOCK -->
  <div class="mb-3">
    <p class="mb-1 text-xs uppercase tracking-wide text-white/40">1. Import at the top of your file (between the ---)</p>
    <div class="copy-block group relative rounded-lg border border-white/10 bg-black/40">
      <button
        class="copy-btn absolute right-2 top-2 rounded-md border border-white/15 bg-white/5 px-2.5 py-1 text-xs text-white/70 transition hover:bg-white/15"
        data-code={importLine}
      >Copy</button>
      <pre class="overflow-x-auto p-4 pr-20 text-sm"><code class="font-mono text-white/80">{importLine}</code></pre>
    </div>
  </div>

  <!-- USAGE BLOCK -->
  <div>
    <p class="mb-1 text-xs uppercase tracking-wide text-white/40">2. Paste where you need it</p>
    <div class="copy-block group relative rounded-lg border border-white/10 bg-black/40">
      <button
        class="copy-btn absolute right-2 top-2 rounded-md border border-white/15 bg-white/5 px-2.5 py-1 text-xs text-white/70 transition hover:bg-white/15"
        data-code={code}
      >Copy</button>
      <pre class="overflow-x-auto p-4 pr-20 text-sm"><code class="font-mono text-white/80">{code}</code></pre>
    </div>
  </div>
</section>
