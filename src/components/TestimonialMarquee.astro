---
// TestimonialMarquee.astro
// Two rows of review cards sliding in opposite directions on an infinite
// loop; both pause on hover. Gives an instant "hundreds of happy clients"
// feel. Pure CSS animation, no JS. Brand navy cards, green stars.
//
// HOW TO USE:
//   <TestimonialMarquee />   (uses shared 6 testimonials, split across 2 rows)

import { testimonials as shared, type Testimonial } from '../data/testimonials';

interface Props { items?: Testimonial[]; }
const { items = shared } = Astro.props;

const mid = Math.ceil(items.length / 2);
const rowA = items.slice(0, mid);
const rowB = items.slice(mid);
// duplicate each row for a seamless loop
const loopA = [...rowA, ...rowA];
const loopB = [...rowB, ...rowB];
---

<section class="tmarquee">
  <div class="tmarquee__mask">
    <div class="tmarquee__row tmarquee__row--left">
      {loopA.map((t) => (
        <figure class="tmarquee__card">
          <div class="tmarquee__stars">★★★★★</div>
          <blockquote>"{t.quote}"</blockquote>
          <figcaption>
            <img src={t.avatar} alt={t.name} loading="lazy" />
            <span><b>{t.name}</b><small>{t.detail}</small></span>
          </figcaption>
        </figure>
      ))}
    </div>
    <div class="tmarquee__row tmarquee__row--right">
      {loopB.map((t) => (
        <figure class="tmarquee__card">
          <div class="tmarquee__stars">★★★★★</div>
          <blockquote>"{t.quote}"</blockquote>
          <figcaption>
            <img src={t.avatar} alt={t.name} loading="lazy" />
            <span><b>{t.name}</b><small>{t.detail}</small></span>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .tmarquee { background: #0d1b2a; padding: 3rem 0; }
  .tmarquee__mask {
    -webkit-mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
    mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .tmarquee__row { display: flex; gap: 1.25rem; width: max-content; }
  .tmarquee__row--left  { animation: tmarquee-left 38s linear infinite; }
  .tmarquee__row--right { animation: tmarquee-right 38s linear infinite; }
  .tmarquee:hover .tmarquee__row { animation-play-state: paused; }

  .tmarquee__card {
    width: 340px;
    flex-shrink: 0;
    padding: 1.5rem;
    border-radius: 1rem;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    margin: 0;
  }
  .tmarquee__stars { color: var(--brand-green); letter-spacing: 2px; font-size: 0.8rem; margin-bottom: 0.6rem; }
  .tmarquee__card blockquote {
    font-family: Georgia, serif; color: rgba(255,255,255,0.9);
    font-size: 1rem; line-height: 1.5; margin: 0 0 1rem;
  }
  .tmarquee__card figcaption { display: flex; align-items: center; gap: 0.7rem; }
  .tmarquee__card img { width: 42px; height: 42px; border-radius: 9999px; object-fit: cover; border: 2px solid var(--brand-green); }
  .tmarquee__card b { display: block; color: #fff; font-size: 0.9rem; }
  .tmarquee__card small { color: rgba(255,255,255,0.5); font-size: 0.75rem; }

  @keyframes tmarquee-left  { to { transform: translateX(-50%); } }
  @keyframes tmarquee-right { from { transform: translateX(-50%); } to { transform: translateX(0); } }

  @media (prefers-reduced-motion: reduce) {
    .tmarquee__row { animation: none; flex-wrap: wrap; }
  }
</style>
