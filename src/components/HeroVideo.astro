---
// HeroVideo.astro
// Main hero: Cloudinary background video + word-by-word headline reveal.
// Pure CSS transitions + vanilla JS. Poster image shows while video loads.
//
// HOW TO USE:
//   <HeroVideo
//     eyebrow="PHILADELPHIA'S #1 WINDOW FILM COMPANY"
//     headline="Philadelphia's glass, transformed."
//     subtitle="Energy savings. UV protection. Safety & security."
//   />
//   Change `video` / `poster` to your own Cloudinary URLs.

interface Props {
  eyebrow?: string;
  headline?: string;
  subtitle?: string;
  video?: string;
  poster?: string;
  ctaText?: string;
  ctaHref?: string;
  secondaryText?: string;
  secondaryHref?: string;
}

const {
  eyebrow = "PHILADELPHIA'S #1 WINDOW FILM COMPANY",
  headline = "Philadelphia's glass, transformed.",
  subtitle = 'Energy savings. UV protection. Safety & security. Done right, every time.',
  video = 'https://res.cloudinary.com/deunehrew/video/upload/f_auto,q_auto,vc_auto/v1781724884/philadelphia-dramatic-sunset-aerial-panorama-dow-2026-01-22-02-38-52-utc_1_ijkuix.mp4',
  poster = '/images/wfp-landing-hero.webp',
  ctaText = 'Get a free quote',
  ctaHref = '/contact/',
  secondaryText = 'See our services',
  secondaryHref = '/services/',
} = Astro.props;

const words = headline.split(' ');
---

<section class="relative isolate flex min-h-[560px] items-center overflow-hidden">
  <video
    class="absolute inset-0 -z-10 h-full w-full object-cover"
    autoplay muted loop playsinline
    poster={poster}
  >
    <source src={video} type="video/mp4" />
  </video>
  <div class="absolute inset-0 -z-10 bg-gradient-to-r from-ink/90 via-ink/70 to-ink/30"></div>

  <div class="mx-auto w-full max-w-6xl px-6 py-20">
    {eyebrow && (
      <p class="mb-5 flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.2em] text-brand-light">
        <span class="inline-block h-1.5 w-1.5 rounded-full bg-brand-light"></span>{eyebrow}
      </p>
    )}
    <h1 class="max-w-3xl font-display text-5xl font-bold leading-[1.05] text-white sm:text-6xl">
      {words.map((w, i) => (
        <span class="hero-word" style="display:inline-block">{w}{i < words.length - 1 ? '\u00A0' : ''}</span>
      ))}
    </h1>
    {subtitle && <p class="mt-6 max-w-xl text-lg text-white/70">{subtitle}</p>}

    <div class="mt-8 flex flex-wrap gap-3">
      {ctaText && <a href={ctaHref} class="rounded-full bg-brand px-7 py-3 font-semibold text-white transition hover:bg-brand-dark">{ctaText}</a>}
      {secondaryText && <a href={secondaryHref} class="rounded-full border border-white/30 px-7 py-3 font-semibold text-white transition hover:bg-white/10">{secondaryText}</a>}
    </div>
  </div>
</section>

<style is:global>
  .hero-word {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }
  .hero-word.visible { opacity: 1; transform: translateY(0); }
  @media (prefers-reduced-motion: reduce) {
    .hero-word { opacity: 1; transform: none; transition: none; }
  }
</style>

<script>
  document.querySelectorAll('.hero-word').forEach((word, i) => {
    setTimeout(() => word.classList.add('visible'), 80 + i * 110);
  });
</script>
