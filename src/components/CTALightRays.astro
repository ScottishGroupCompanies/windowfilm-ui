---
// CTALightRays.astro
// Cinematic CTA band: animated diagonal light rays (pure CSS gradients,
// slowly drifting) pour across a deep navy section; a frosted-glass panel
// holds the headline and button, with a shine sweep crossing the glass on
// loop. On-brand for a window film company — the section IS light + glass.
// No images, no libraries.
//
// HOW TO USE:
//   <CTALightRays />

interface Props { heading?: string; sub?: string; ctaText?: string; ctaHref?: string; }
const {
  heading = 'Your glass. Transformed.',
  sub = 'Professional window film — installed right, backed for life.',
  ctaText = 'Book your free consultation',
  ctaHref = '/contact/',
} = Astro.props;
---

<section class="ctar">
  <!-- animated god rays -->
  <div class="ctar__rays" aria-hidden="true">
    <span class="ctar__ray ctar__ray--1"></span>
    <span class="ctar__ray ctar__ray--2"></span>
    <span class="ctar__ray ctar__ray--3"></span>
    <span class="ctar__ray ctar__ray--4"></span>
  </div>

  <div class="ctar__glass">
    <span class="ctar__shine" aria-hidden="true"></span>
    <p class="ctar__eyebrow">Window film professionals</p>
    <h2 class="ctar__title font-display">{heading}</h2>
    <p class="ctar__sub">{sub}</p>
    <a href={ctaHref} class="ctar__btn">{ctaText}</a>
  </div>
</section>

<style>
  .ctar {
    position: relative; overflow: hidden;
    background: linear-gradient(160deg, #0a1420, var(--ink, #0d1b2a) 55%, #12293f);
    padding: 6rem 1.5rem;
    display: flex; justify-content: center;
  }

  /* --- rays --- */
  .ctar__rays { position: absolute; inset: -20%; pointer-events: none; }
  .ctar__ray {
    position: absolute; top: -30%; bottom: -30%;
    width: 140px;
    background: linear-gradient(to bottom, rgba(124,179,66,0.16), rgba(255,255,255,0.05) 55%, transparent);
    transform: rotate(18deg);
    filter: blur(18px);
    animation: ctar-drift 11s ease-in-out infinite alternate;
  }
  .ctar__ray--1 { left: 8%; animation-delay: 0s; }
  .ctar__ray--2 { left: 30%; width: 90px; opacity: 0.7; animation-delay: -3s; }
  .ctar__ray--3 { left: 55%; width: 180px; opacity: 0.55; animation-delay: -6s; }
  .ctar__ray--4 { left: 80%; width: 70px; opacity: 0.8; animation-delay: -9s; }
  @keyframes ctar-drift {
    from { transform: rotate(18deg) translateX(-30px); opacity: 0.5; }
    to   { transform: rotate(18deg) translateX(30px); opacity: 1; }
  }

  /* --- glass panel --- */
  .ctar__glass {
    position: relative; overflow: hidden;
    max-width: 40rem; width: 100%;
    text-align: center;
    background: rgba(255,255,255,0.06);
    backdrop-filter: blur(14px) saturate(130%);
    -webkit-backdrop-filter: blur(14px) saturate(130%);
    border: 1px solid rgba(255,255,255,0.16);
    border-radius: 1.5rem;
    padding: 3.5rem 2.5rem;
    box-shadow: 0 30px 80px rgba(0,0,0,0.45), inset 0 1px 0 rgba(255,255,255,0.25);
  }
  .ctar__shine {
    position: absolute; top: 0; bottom: 0; width: 45%;
    background: linear-gradient(105deg, transparent, rgba(255,255,255,0.14), transparent);
    transform: skewX(-18deg);
    left: -60%;
    animation: ctar-shine 5.5s ease-in-out infinite;
    pointer-events: none;
  }
  @keyframes ctar-shine {
    0%, 55% { left: -60%; }
    85%, 100% { left: 130%; }
  }

  .ctar__eyebrow {
    color: var(--brand-green-light);
    font-size: 0.72rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.24em;
    margin: 0 0 1rem;
  }
  .ctar__title { color: #fff; font-size: clamp(2rem, 4.5vw, 3rem); font-weight: 800; margin: 0 0 0.75rem; }
  .ctar__sub { color: rgba(255,255,255,0.65); margin: 0 0 2rem; font-size: 1.05rem; }
  .ctar__btn {
    display: inline-block;
    background: var(--brand-green); color: var(--ink, #0d1b2a);
    font-weight: 700; padding: 0.95rem 2.2rem; border-radius: 9999px; text-decoration: none;
    box-shadow: 0 12px 32px rgba(124,179,66,0.35);
    transition: transform 0.25s ease, box-shadow 0.25s ease, background 0.25s ease;
  }
  .ctar__btn:hover {
    transform: translateY(-2px);
    background: var(--brand-green-light);
    box-shadow: 0 18px 42px rgba(124,179,66,0.5);
  }

  @media (prefers-reduced-motion: reduce) {
    .ctar__ray, .ctar__shine { animation: none; }
  }
</style>
