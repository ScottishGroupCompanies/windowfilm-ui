---
// AccordionFAQ.astro
// Classic FAQ accordion — each question expands smoothly on click with a
// rotating +/− icon. Only one open at a time (configurable). Pure CSS +
// vanilla JS. Real window-film questions included. Great for SEO + objections.
//
// HOW TO USE:
//   <AccordionFAQ />   (defaults to 6 window-film FAQs)
//   items={[{ q, a }]}   ·   single={false} to allow multiple open

interface QA { q: string; a: string; }
interface Props { heading?: string; sub?: string; items?: QA[]; single?: boolean; }
const {
  heading = 'Frequently asked questions',
  sub = 'Everything you need to know before your install.',
  single = true,
  items = [
    { q: 'Will window film damage my glass?', a: 'No. When professionally installed and matched to your glass type, quality film will not damage your windows. In fact, it adds a layer of protection. We assess every pane before installing to ensure the right film for your specific glass.' },
    { q: 'How long does window film last?', a: 'Professional-grade residential and commercial films typically last 15–20+ years, and most come with a manufacturer warranty. Our installs are backed for life against peeling, bubbling, and discoloration.' },
    { q: 'How long does installation take?', a: 'Most residential projects are completed in a single day. Larger commercial jobs are scheduled around your operations, often after hours, so there is minimal disruption to your business.' },
    { q: 'Can I clean film-treated windows normally?', a: 'Yes. After a short curing period (about 30 days), you can clean film-treated glass with any non-abrasive cleaner and a soft cloth. We recommend avoiding ammonia-based products on some films — we will leave you simple care instructions.' },
    { q: 'Will the film make my rooms dark?', a: 'Not necessarily. Modern spectrally selective films reject heat and UV while staying nearly clear, so your rooms stay bright. We will match the visible light level to your preference during the consultation.' },
    { q: 'Do you offer a warranty?', a: 'Yes — every installation is backed by a lifetime warranty on the film and our workmanship, in addition to the manufacturer coverage. If anything is not right, we make it right.' },
  ],
} = Astro.props;
---

<section class="faq">
  <div class="faq__head">
    <h2 class="faq__title font-display">{heading}</h2>
    <p class="faq__sub">{sub}</p>
  </div>

  <div class="faq__list" data-single={single ? 'true' : 'false'}>
    {items.map((item, i) => (
      <div class={`faq__item ${i === 0 ? 'is-open' : ''}`} data-item>
        <button class="faq__q" data-q aria-expanded={i === 0 ? 'true' : 'false'}>
          <span>{item.q}</span>
          <span class="faq__icon" aria-hidden="true"><span></span><span></span></span>
        </button>
        <div class="faq__a"><div class="faq__a-inner"><p>{item.a}</p></div></div>
      </div>
    ))}
  </div>
</section>

<style is:global>
  .faq { background: var(--ink, #0d1b2a); padding: 4rem 1.5rem; }
  .faq__head { max-width: 42rem; margin: 0 auto 2.5rem; text-align: center; }
  .faq__title { color: #fff; font-size: clamp(1.6rem, 3.5vw, 2.4rem); font-weight: 700; margin: 0 0 0.5rem; }
  .faq__sub { color: rgba(255,255,255,0.5); margin: 0; }
  .faq__list { max-width: 44rem; margin: 0 auto; display: flex; flex-direction: column; gap: 0.75rem; }

  .faq__item {
    background: var(--slate, #12293f);
    border: 1px solid rgba(255,255,255,0.08); border-radius: 0.85rem; overflow: hidden;
    transition: border-color 0.3s ease;
  }
  .faq__item.is-open { border-color: rgba(124,179,66,0.5); }
  .faq__q {
    width: 100%; display: flex; align-items: center; justify-content: space-between; gap: 1rem;
    background: none; border: none; cursor: pointer; text-align: left;
    padding: 1.15rem 1.35rem; color: #fff; font-size: 1rem; font-weight: 600;
    font-family: inherit;
  }
  .faq__icon { position: relative; flex-shrink: 0; width: 20px; height: 20px; }
  .faq__icon span {
    position: absolute; top: 50%; left: 50%; width: 14px; height: 2px; border-radius: 2px;
    background: var(--brand-green); transform: translate(-50%, -50%); transition: transform 0.3s ease;
  }
  .faq__icon span:last-child { transform: translate(-50%, -50%) rotate(90deg); }
  .faq__item.is-open .faq__icon span:last-child { transform: translate(-50%, -50%) rotate(0); }

  .faq__a { display: grid; grid-template-rows: 0fr; transition: grid-template-rows 0.35s ease; }
  .faq__item.is-open .faq__a { grid-template-rows: 1fr; }
  .faq__a-inner { overflow: hidden; }
  .faq__a-inner p { margin: 0; padding: 0 1.35rem 1.25rem; color: rgba(255,255,255,0.6); font-size: 0.92rem; line-height: 1.65; }

  @media (prefers-reduced-motion: reduce) {
    .faq__a { transition: none; } .faq__icon span { transition: none; }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('.faq__list').forEach((list) => {
    const single = list.dataset.single === 'true';
    const items = Array.from(list.querySelectorAll<HTMLElement>('[data-item]'));
    items.forEach((item) => {
      const btn = item.querySelector<HTMLElement>('[data-q]');
      btn?.addEventListener('click', () => {
        const isOpen = item.classList.contains('is-open');
        if (single) items.forEach((it) => { it.classList.remove('is-open'); it.querySelector('[data-q]')?.setAttribute('aria-expanded', 'false'); });
        item.classList.toggle('is-open', !isOpen);
        btn.setAttribute('aria-expanded', String(!isOpen));
      });
    });
  });
</script>
