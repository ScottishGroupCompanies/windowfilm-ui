---
// BeforeAfterSlider.astro
// Signature before/after comparison slider — drag (or touch) to reveal
// the "after" image over the "before" image. Pure CSS + vanilla JS,
// no libraries. This is the single most persuasive visual for a window
// film company: it SHOWS the transformation instead of describing it.
//
// HOW TO USE:
//   <BeforeAfterSlider
//     before="https://res.cloudinary.com/.../no-film.png"
//     after="https://res.cloudinary.com/.../with-film.png"
//     beforeLabel="Without film"
//     afterLabel="With film"
//   />
//   Drop several on a page for different rooms/scenes — each gets its
//   own independent slider (they don't interfere with each other).

interface Props {
  before: string;
  after: string;
  beforeLabel?: string;
  afterLabel?: string;
  startAt?: number; // initial position, 0-100
}

const {
  before,
  after,
  beforeLabel = 'Without film',
  afterLabel = 'With film',
  startAt = 50,
} = Astro.props;

// unique id so multiple sliders on one page don't collide
const uid = `bas-${Math.random().toString(36).slice(2, 9)}`;
---

<div class="before-after" id={uid} style={`--pos:${startAt}%`}>
  <div class="before-after__frame">
    <img src={before} alt={beforeLabel} class="before-after__img before-after__img--before" draggable="false" />
    <div class="before-after__after-wrap">
      <img src={after} alt={afterLabel} class="before-after__img before-after__img--after" draggable="false" />
    </div>

    <span class="before-after__tag before-after__tag--before">{beforeLabel}</span>
    <span class="before-after__tag before-after__tag--after">{afterLabel}</span>

    <div class="before-after__handle" role="slider" tabindex="0"
         aria-label="Drag to compare before and after"
         aria-valuemin="0" aria-valuemax="100" aria-valuenow={startAt}>
      <span class="before-after__handle-grip">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M8 7L3 12L8 17M16 7L21 12L16 17" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </span>
    </div>
  </div>
</div>

<style is:global>
  .before-after__frame {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-radius: 1rem;
    cursor: ew-resize;
    user-select: none;
    background: #000;
  }
  .before-after__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    pointer-events: none;
  }
  .before-after__after-wrap {
    position: absolute;
    inset: 0;
    width: var(--pos, 50%);
    overflow: hidden;
  }
  .before-after__after-wrap .before-after__img {
    width: var(--frame-width, 100%);
  }

  .before-after__handle {
    position: absolute;
    top: 0;
    bottom: 0;
    left: var(--pos, 50%);
    width: 3px;
    background: white;
    transform: translateX(-50%);
    cursor: ew-resize;
  }
  .before-after__handle-grip {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 40px;
    height: 40px;
    border-radius: 9999px;
    background: white;
    color: #0d1b2a;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 16px rgba(0,0,0,0.35);
    transition: transform 0.15s ease;
  }
  .before-after:active .before-after__handle-grip { transform: translate(-50%, -50%) scale(1.08); }

  .before-after__tag {
    position: absolute;
    bottom: 14px;
    padding: 5px 12px;
    border-radius: 9999px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    background: rgba(13,27,42,0.75);
    color: white;
    backdrop-filter: blur(4px);
    pointer-events: none;
    z-index: 2;
  }
  .before-after__tag--before { left: 14px; }
  .before-after__tag--after { right: 14px; }

  @media (prefers-reduced-motion: reduce) {
    .before-after__handle-grip { transition: none; }
  }
</style>

<script>
  function initBeforeAfter(root: HTMLElement) {
    const frame = root.querySelector<HTMLElement>('.before-after__frame')!;
    const afterWrap = root.querySelector<HTMLElement>('.before-after__after-wrap')!;
    const afterImg = root.querySelector<HTMLImageElement>('.before-after__img--after')!;
    const handle = root.querySelector<HTMLElement>('.before-after__handle')!;

    function setFrameWidth() {
      // keep the "after" image the same rendered width as the frame,
      // even though its wrapper is clipped narrower.
      afterImg.style.setProperty('--frame-width', `${frame.offsetWidth}px`);
    }

    function setPos(clientX: number) {
      const rect = frame.getBoundingClientRect();
      let pct = ((clientX - rect.left) / rect.width) * 100;
      pct = Math.max(0, Math.min(100, pct));
      root.style.setProperty('--pos', pct + '%');
      handle.setAttribute('aria-valuenow', String(Math.round(pct)));
    }

    let dragging = false;
    const start = () => (dragging = true);
    const stop = () => (dragging = false);
    const move = (clientX: number) => { if (dragging) setPos(clientX); };

    frame.addEventListener('mousedown', (e) => { start(); setPos(e.clientX); });
    window.addEventListener('mouseup', stop);
    window.addEventListener('mousemove', (e) => move(e.clientX));

    frame.addEventListener('touchstart', (e) => { start(); setPos(e.touches[0].clientX); }, { passive: true });
    window.addEventListener('touchend', stop);
    window.addEventListener('touchmove', (e) => move(e.touches[0].clientX), { passive: true });

    handle.addEventListener('keydown', (e) => {
      const rect = frame.getBoundingClientRect();
      const current = parseFloat(getComputedStyle(root).getPropertyValue('--pos')) || 50;
      if (e.key === 'ArrowLeft') setPos(rect.left + (rect.width * (current - 5)) / 100);
      if (e.key === 'ArrowRight') setPos(rect.left + (rect.width * (current + 5)) / 100);
    });

    window.addEventListener('resize', setFrameWidth);
    setFrameWidth();
  }

  document.querySelectorAll<HTMLElement>('.before-after').forEach(initBeforeAfter);
</script>
