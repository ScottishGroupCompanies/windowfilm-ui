---
// TeamHoverReveal.astro
// Large, editorial photos in grayscale; on hover, a green-tinted overlay
// rises with the full bio, name and role slide up. Feels premium and
// magazine-like — best when you want big portraits over lots of text.
// Pure CSS.
//
// HOW TO USE:
//   <TeamHoverReveal />   (uses the shared 8 team members)

import { team as shared, type TeamMember } from '../data/team';

interface Props { heading?: string; sub?: string; members?: TeamMember[]; }
const {
  heading = 'The people behind every install',
  sub = 'Hover a face to meet the team.',
  members = shared,
} = Astro.props;
---

<section class="thr">
  <div class="thr__head">
    <h2 class="thr__title font-display">{heading}</h2>
    <p class="thr__sub">{sub}</p>
  </div>
  <div class="thr__grid">
    {members.map((m) => (
      <article class="thr__card">
        <img src={m.photo} alt={m.name} loading="lazy" />
        <div class="thr__overlay">
          <p class="thr__bio">{m.bio}</p>
        </div>
        <div class="thr__caption">
          <h3>{m.name}</h3>
          <p>{m.role}</p>
        </div>
      </article>
    ))}
  </div>
</section>

<style>
  .thr { background: var(--ink, #0d1b2a); padding: 4rem 1.5rem; }
  .thr__head { max-width: 40rem; margin: 0 auto 2.5rem; text-align: center; }
  .thr__title { color: #fff; font-size: clamp(1.6rem, 3.5vw, 2.4rem); font-weight: 700; margin: 0 0 0.5rem; }
  .thr__sub { color: rgba(255,255,255,0.5); margin: 0; }

  .thr__grid {
    max-width: 72rem; margin: 0 auto;
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem;
  }
  .thr__card {
    position: relative; aspect-ratio: 3/4; border-radius: 0.9rem; overflow: hidden;
    background: var(--slate, #12293f);
  }
  .thr__card img {
    position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover;
    filter: grayscale(0.9) contrast(1.05);
    transition: filter 0.4s ease, transform 0.4s ease;
  }
  .thr__card:hover img { filter: grayscale(0); transform: scale(1.05); }

  .thr__overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(124,179,66,0.94), rgba(13,27,42,0.75) 60%, transparent);
    display: flex; align-items: flex-end;
    padding: 1.1rem;
    opacity: 0; transform: translateY(8px);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  .thr__card:hover .thr__overlay { opacity: 1; transform: translateY(0); }
  .thr__bio { color: #0d1b2a; font-size: 0.78rem; line-height: 1.45; font-weight: 500; margin: 0; }

  .thr__caption {
    position: absolute; left: 1.1rem; bottom: 1.1rem;
    transition: opacity 0.25s ease;
  }
  .thr__card:hover .thr__caption { opacity: 0; }
  .thr__caption h3 { color: #fff; font-family: Georgia, serif; font-size: 1.05rem; margin: 0 0 0.1rem; text-shadow: 0 2px 8px rgba(0,0,0,0.6); }
  .thr__caption p { color: var(--brand-green-light); font-size: 0.75rem; font-weight: 600; margin: 0; text-shadow: 0 2px 8px rgba(0,0,0,0.6); }

  @media (max-width: 900px) { .thr__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (prefers-reduced-motion: reduce) {
    .thr__card img, .thr__overlay, .thr__caption { transition: none; }
  }
</style>
