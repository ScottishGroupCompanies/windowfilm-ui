---
// CTAAvatars.astro
// Horizontal CTA with an overlapping avatar stack (slightly rotated, tooltip
// on hover), 5 green stars, trust count, and a CTA button whose arrow slides
// on hover. Avatars pop in staggered on scroll. Pure CSS + tiny JS.
//
// HOW TO USE:
//   <CTAAvatars />   (uses the 6 testimonial photos in /images/)

interface Avatar { src: string; name: string; role: string; }
interface Props {
  heading?: string; sub?: string; trust?: string;
  ctaText?: string; ctaHref?: string; avatars?: Avatar[];
}
const {
  heading = 'Ready to transform your glass?',
  sub = 'Free consultation, transparent pricing, and a lifetime warranty on every install.',
  trust = 'Trusted by 2,400+ homeowners & businesses',
  ctaText = 'Get a Free Quote',
  ctaHref = '/contact/',
  avatars = [
    { src: '/images/testimonial-1.jpg', name: 'David R.', role: 'Center City' },
    { src: '/images/testimonial-2.jpg', name: 'Alex & Maria', role: 'Fishtown' },
    { src: '/images/testimonial-3.jpg', name: 'James W.', role: 'South Philly' },
    { src: '/images/testimonial-4.jpg', name: 'Michael T.', role: 'Old City' },
    { src: '/images/testimonial-5.jpg', name: 'Sarah M.', role: 'Manayunk' },
    { src: '/images/testimonial-6.jpg', name: 'Janet K.', role: 'Rittenhouse' },
  ],
} = Astro.props;
---

<section class="ctav">
  <div class="ctav__inner">
    <div class="ctav__left">
      <h2 class="ctav__title font-display">{heading}</h2>
      <p class="ctav__sub">{sub}</p>
      <div class="ctav__proof">
        <div class="ctav__stack">
          {avatars.map((a, i) => (
            <span class="ctav__avatar" style={`--i:${i}; --r:${(i % 2 === 0 ? -1 : 1) * (2 + i)}deg`}>
              <img src={a.src} alt={a.name} loading="lazy" />
              <span class="ctav__tip"><b>{a.name}</b><small>{a.role}</small></span>
            </span>
          ))}
        </div>
        <div class="ctav__meta">
          <span class="ctav__stars">★★★★★</span>
          <span class="ctav__trust">{trust}</span>
        </div>
      </div>
    </div>
    <a href={ctaHref} class="ctav__btn">{ctaText}<span class="ctav__arrow">→</span></a>
  </div>
</section>

<style is:global>
  .ctav { background: var(--ink, #0d1b2a); padding: 4.5rem 1.5rem; }
  .ctav__inner {
    max-width: 68rem; margin: 0 auto;
    display: flex; align-items: center; justify-content: space-between; gap: 2.5rem;
    flex-wrap: wrap;
  }
  .ctav__title { color: #fff; font-size: clamp(1.7rem, 3.5vw, 2.5rem); font-weight: 700; margin: 0 0 0.6rem; }
  .ctav__sub { color: rgba(255,255,255,0.55); max-width: 34rem; margin: 0 0 1.5rem; line-height: 1.6; }

  .ctav__proof { display: flex; align-items: center; gap: 1.25rem; flex-wrap: wrap; }
  .ctav__stack { display: flex; }
  .ctav__avatar {
    position: relative; display: block;
    width: 52px; height: 52px; margin-left: -14px;
    border-radius: 9999px; border: 2.5px solid var(--ink, #0d1b2a);
    transform: rotate(var(--r, 0deg)) scale(0);
    transition: transform 0.45s cubic-bezier(0.34, 1.56, 0.64, 1);
    transition-delay: calc(var(--i) * 70ms);
    cursor: pointer; z-index: calc(10 + var(--i));
  }
  .ctav.is-visible .ctav__avatar { transform: rotate(var(--r, 0deg)) scale(1); }
  .ctav__avatar:first-child { margin-left: 0; }
  .ctav__avatar img { width: 100%; height: 100%; border-radius: 9999px; object-fit: cover; }
  .ctav__avatar:hover { transform: rotate(0deg) scale(1.15) !important; z-index: 99; transition-delay: 0ms; }

  .ctav__tip {
    position: absolute; bottom: calc(100% + 10px); left: 50%;
    transform: translateX(-50%) translateY(6px);
    background: var(--brand-green); color: var(--ink, #0d1b2a);
    padding: 0.4rem 0.75rem; border-radius: 0.5rem;
    white-space: nowrap; text-align: center;
    opacity: 0; pointer-events: none;
    transition: opacity 0.25s ease, transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
    box-shadow: 0 8px 20px rgba(0,0,0,0.35);
  }
  .ctav__avatar:hover .ctav__tip { opacity: 1; transform: translateX(-50%) translateY(0); }
  .ctav__tip b { display: block; font-size: 0.78rem; }
  .ctav__tip small { display: block; font-size: 0.68rem; opacity: 0.75; }

  .ctav__meta { display: flex; flex-direction: column; gap: 0.15rem; }
  .ctav__stars { color: var(--brand-green); letter-spacing: 2px; font-size: 0.9rem; }
  .ctav__trust { color: rgba(255,255,255,0.5); font-size: 0.82rem; }

  .ctav__btn {
    display: inline-flex; align-items: center; gap: 0.5rem;
    background: linear-gradient(120deg, var(--brand-green), var(--brand-green-light));
    color: var(--ink, #0d1b2a); font-weight: 700; font-size: 1rem;
    padding: 0.9rem 1.75rem; border-radius: 9999px; text-decoration: none;
    box-shadow: 0 12px 30px rgba(124,179,66,0.35);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    white-space: nowrap;
  }
  .ctav__btn:hover { transform: translateY(-2px); box-shadow: 0 16px 38px rgba(124,179,66,0.45); }
  .ctav__arrow { transition: transform 0.25s ease; }
  .ctav__btn:hover .ctav__arrow { transform: translateX(4px); }

  @media (prefers-reduced-motion: reduce) {
    .ctav__avatar { transform: rotate(var(--r, 0deg)) scale(1); transition: none; }
    .ctav__btn, .ctav__arrow, .ctav__tip { transition: none; }
  }
</style>

<script>
  const io = new IntersectionObserver((entries) => {
    entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('is-visible'); io.unobserve(e.target); } });
  }, { threshold: 0.3 });
  document.querySelectorAll('.ctav').forEach((el) => io.observe(el));
</script>
