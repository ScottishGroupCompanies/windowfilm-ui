---
// LogoCloudSwap.astro
// A small set of slots (default 6) that cycle through the full logo list —
// each slot flips on a timer to reveal the next brand, giving a sense of
// "many partners" in a compact footprint. Slots swap at staggered times so
// they don't all flip at once. Vanilla JS + CSS 3D flip.
//
// HOW TO USE:
//   <LogoCloudSwap slots={6} />   (shared 12 brand logos rotating through 6 slots)

import { brandLogos, type BrandLogo } from '../data/logos';

interface Props { heading?: string; sub?: string; items?: BrandLogo[]; slots?: number; interval?: number; }
const {
  heading = 'Trusted by modern operators',
  sub = 'From homes to high-rises across the Delaware Valley.',
  items = brandLogos,
  slots = 6,
  interval = 2600,
} = Astro.props;

const initial = items.slice(0, slots);
const data = JSON.stringify({ all: items, slots, interval });
---

<section class="lcsw" data-config={data}>
  <div class="lcsw__head">
    <h2 class="lcsw__title font-display">{heading}</h2>
    <p class="lcsw__sub">{sub}</p>
  </div>
  <div class="lcsw__row">
    {initial.map((logo, i) => (
      <div class="lcsw__slot" data-slot={i}>
        <div class="lcsw__flip">
          <img src={logo.src} alt={logo.alt} loading="lazy" />
        </div>
      </div>
    ))}
  </div>
</section>

<style is:global>
  .lcsw { background: var(--ink, #0d1b2a); padding: 4rem 1.5rem; }
  .lcsw__head { text-align: center; max-width: 40rem; margin: 0 auto 2.5rem; }
  .lcsw__title { color: #fff; font-size: clamp(1.4rem, 3vw, 2rem); font-weight: 600; margin: 0 0 0.5rem; }
  .lcsw__sub { color: rgba(255,255,255,0.5); font-size: 0.95rem; margin: 0; }
  .lcsw__row {
    max-width: 60rem; margin: 0 auto;
    display: flex; flex-wrap: wrap; justify-content: center; gap: 2.5rem;
  }
  .lcsw__slot { width: 140px; height: 72px; perspective: 600px; }
  .lcsw__flip {
    width: 100%; height: 100%;
    display: flex; align-items: center; justify-content: center;
    background: #fff;
    border-radius: 0.75rem;
    box-shadow: 0 6px 18px rgba(0,0,0,0.2);
    transition: transform 0.5s ease, box-shadow 0.3s ease;
    transform-style: preserve-3d;
  }
  .lcsw__flip.flipping { transform: rotateX(90deg); }
  .lcsw__flip img {
    max-height: 36px; max-width: 80%; object-fit: contain;
  }
  .lcsw__slot:hover .lcsw__flip { box-shadow: 0 10px 26px rgba(124,179,66,0.4); }
  @media (prefers-reduced-motion: reduce) { .lcsw__flip { transition: none; } }
</style>

<script>
  document.querySelectorAll<HTMLElement>('.lcsw').forEach((root) => {
    const cfg = JSON.parse(root.dataset.config || '{}');
    const { all, slots, interval } = cfg;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduce || all.length <= slots) return;

    const slotEls = Array.from(root.querySelectorAll<HTMLElement>('.lcsw__slot'));
    let nextPool = slots; // index into `all` for the next logo to show

    slotEls.forEach((slot, i) => {
      const flip = slot.querySelector<HTMLElement>('.lcsw__flip')!;
      const img = flip.querySelector<HTMLImageElement>('img')!;
      // stagger each slot's timer so they don't flip in unison
      setTimeout(() => {
        setInterval(() => {
          flip.classList.add('flipping');
          setTimeout(() => {
            const logo = all[nextPool % all.length];
            nextPool++;
            img.src = logo.src; img.alt = logo.alt;
            flip.classList.remove('flipping');
          }, 260);
        }, interval);
      }, i * (interval / slots));
    });
  });
</script>
