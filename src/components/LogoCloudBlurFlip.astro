---
// LogoCloudBlurFlip.astro
// Brand logos animate in with a blur-to-focus + subtle 3D flip, staggered,
// when the section scrolls into view. Grid layout, logos rest in grayscale
// and color up on hover. Pure CSS + IntersectionObserver, no libraries.
//
// HOW TO USE:
//   <LogoCloudBlurFlip />   (uses the shared 12 brand logos)
//   <LogoCloudBlurFlip heading="..." sub="..." items={[{src, alt}]} />

import { brandLogos, type BrandLogo } from '../data/logos';

interface Props { heading?: string; sub?: string; items?: BrandLogo[]; }
const {
  heading = 'Trusted by leading businesses',
  sub = 'We install every major brand of window film.',
  items = brandLogos,
} = Astro.props;
---

<section class="lcbf">
  <div class="lcbf__head">
    <h2 class="lcbf__title font-display">{heading}</h2>
    <p class="lcbf__sub">{sub}</p>
  </div>
  <div class="lcbf__grid">
    {items.map((logo, i) => (
      <div class="lcbf__cell" style={`--d:${i * 70}ms`}>
        <img src={logo.src} alt={logo.alt} loading="lazy" />
      </div>
    ))}
  </div>
</section>

<style is:global>
  .lcbf { background: var(--ink, #0d1b2a); padding: 4rem 1.5rem; }
  .lcbf__head { text-align: center; max-width: 40rem; margin: 0 auto 2.5rem; }
  .lcbf__title { color: #fff; font-size: clamp(1.4rem, 3vw, 2rem); font-weight: 600; margin: 0 0 0.5rem; }
  .lcbf__sub { color: rgba(255,255,255,0.5); font-size: 0.95rem; margin: 0; }
  .lcbf__grid {
    max-width: 64rem; margin: 0 auto;
    display: grid; grid-template-columns: repeat(6, 1fr); gap: 1px;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 1rem; overflow: hidden;
  }
  .lcbf__cell {
    display: flex; align-items: center; justify-content: center;
    background: var(--ink, #0d1b2a);
    padding: 1.75rem 1rem;
    opacity: 0; filter: blur(10px);
    transform: perspective(600px) rotateX(-30deg);
    transition: opacity 0.6s ease, filter 0.6s ease, transform 0.6s ease, background 0.3s ease;
    transition-delay: var(--d, 0ms);
  }
  .lcbf.is-visible .lcbf__cell { opacity: 1; filter: blur(0); transform: perspective(600px) rotateX(0); }
  .lcbf__cell:hover { background: rgba(124,179,66,0.08); }
  .lcbf__cell img {
    max-height: 34px; max-width: 100%; object-fit: contain;
    filter: grayscale(1) brightness(0) invert(1) opacity(0.7);
    transition: filter 0.3s ease, transform 0.3s ease;
  }
  .lcbf__cell:hover img { filter: none; transform: scale(1.06); }

  @media (max-width: 768px) { .lcbf__grid { grid-template-columns: repeat(3, 1fr); } }
  @media (prefers-reduced-motion: reduce) {
    .lcbf__cell { opacity: 1; filter: none; transform: none; transition: background 0.3s ease; }
  }
</style>

<script>
  const io = new IntersectionObserver((entries) => {
    entries.forEach((e) => {
      if (!e.isIntersecting) return;
      e.target.classList.add('is-visible');
      io.unobserve(e.target);
    });
  }, { threshold: 0.2 });
  document.querySelectorAll('.lcbf').forEach((el) => io.observe(el));
</script>
