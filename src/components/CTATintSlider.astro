---
// CTATintSlider.astro
// The product demos itself INSIDE the CTA: a bright room photo fills the
// section, and a slider lets the visitor "apply tint" live — dragging it
// darkens the glass, cools the glare, and updates a VLT (visible light
// transmission) readout. Ends on the quote button. Pure CSS + vanilla JS.
//
// HOW TO USE:
//   <CTATintSlider />
//   <CTATintSlider bg="https://res.cloudinary.com/.../bright-room.png" />

interface Props {
  heading?: string; sub?: string; ctaText?: string; ctaHref?: string; bg?: string;
}
const {
  heading = 'Find your perfect tint.',
  sub = 'Slide to preview how window film tames glare and heat — then get it installed for real.',
  ctaText = 'Get a Free Quote',
  ctaHref = '/contact/',
  bg = 'https://res.cloudinary.com/deunehrew/image/upload/v1783021712/hf_20260702_194725_d1e28908-f22f-4b0a-b57a-cde43f0679e4_tkvrcf.png',
} = Astro.props;

const uid = `ctat-${Math.random().toString(36).slice(2, 8)}`;
---

<section class="ctat" id={uid}>
  <img class="ctat__bg" src={bg} alt="" aria-hidden="true" />
  <div class="ctat__tint" aria-hidden="true"></div>

  <div class="ctat__inner">
    <h2 class="ctat__title font-display">{heading}</h2>
    <p class="ctat__sub">{sub}</p>

    <div class="ctat__control">
      <span class="ctat__label">Clear</span>
      <input type="range" min="0" max="80" value="35" class="ctat__range" aria-label="Tint level preview" />
      <span class="ctat__label">Limo</span>
    </div>
    <p class="ctat__vlt">VLT <b class="ctat__vlt-num">65</b>% · visible light transmission</p>

    <a href={ctaHref} class="ctat__btn">{ctaText} →</a>
  </div>
</section>

<style is:global>
  .ctat {
    position: relative; overflow: hidden;
    padding: 5rem 1.5rem;
    text-align: center;
  }
  .ctat__bg {
    position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover;
  }
  .ctat__tint {
    position: absolute; inset: 0;
    background: var(--ink, #0d1b2a);
    opacity: var(--tint, 0.35);
    transition: opacity 0.15s linear;
  }
  .ctat__inner { position: relative; max-width: 40rem; margin: 0 auto; }
  .ctat__title {
    color: #fff; font-size: clamp(2rem, 4.5vw, 3.2rem); font-weight: 800; margin: 0 0 0.6rem;
    text-shadow: 0 2px 24px rgba(0,0,0,0.5);
  }
  .ctat__sub { color: rgba(255,255,255,0.85); margin: 0 0 2rem; text-shadow: 0 1px 12px rgba(0,0,0,0.5); }

  .ctat__control {
    display: flex; align-items: center; gap: 1rem;
    background: rgba(13,27,42,0.55);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 9999px;
    padding: 0.9rem 1.5rem;
    max-width: 26rem; margin: 0 auto 0.75rem;
  }
  .ctat__label { color: rgba(255,255,255,0.7); font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; }
  .ctat__range {
    flex: 1; appearance: none; height: 6px; border-radius: 9999px;
    background: linear-gradient(to right, rgba(255,255,255,0.9), rgba(13,27,42,0.9));
    outline: none; cursor: ew-resize;
  }
  .ctat__range::-webkit-slider-thumb {
    appearance: none; width: 26px; height: 26px; border-radius: 9999px;
    background: var(--brand-green); border: 3px solid #fff;
    box-shadow: 0 4px 14px rgba(0,0,0,0.4); cursor: grab;
  }
  .ctat__range::-moz-range-thumb {
    width: 26px; height: 26px; border-radius: 9999px;
    background: var(--brand-green); border: 3px solid #fff;
    box-shadow: 0 4px 14px rgba(0,0,0,0.4); cursor: grab;
  }
  .ctat__vlt { color: rgba(255,255,255,0.75); font-size: 0.82rem; margin: 0 0 2rem; text-shadow: 0 1px 8px rgba(0,0,0,0.6); }
  .ctat__vlt b { color: var(--brand-green-light); font-size: 1rem; }

  .ctat__btn {
    display: inline-block;
    background: var(--brand-green); color: var(--ink, #0d1b2a);
    font-weight: 700; font-size: 1rem;
    padding: 0.95rem 2rem; border-radius: 9999px; text-decoration: none;
    box-shadow: 0 12px 32px rgba(0,0,0,0.4);
    transition: transform 0.25s ease, background 0.25s ease;
  }
  .ctat__btn:hover { transform: translateY(-2px); background: var(--brand-green-light); }

  @media (prefers-reduced-motion: reduce) { .ctat__tint { transition: none; } }
</style>

<script>
  document.querySelectorAll<HTMLElement>('.ctat').forEach((root) => {
    const range = root.querySelector<HTMLInputElement>('.ctat__range')!;
    const tint = root.querySelector<HTMLElement>('.ctat__tint')!;
    const vlt = root.querySelector<HTMLElement>('.ctat__vlt-num')!;
    function apply() {
      const v = Number(range.value); // 0..80
      tint.style.setProperty('--tint', String(v / 100));
      vlt.textContent = String(100 - v);
    }
    range.addEventListener('input', apply);
    apply();
  });
</script>
