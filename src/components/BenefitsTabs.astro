---
// BenefitsTabs.astro
// Tabbed benefits section: click a tab to switch its image set + panel.
// Vanilla JS, no libraries. (Ported from the standalone Benefits.astro.)
//
// HOW TO USE:
//   <BenefitsTabs tabs={[{ key, label, title, desc, img }, ...]} />

interface Tab { key: string; label: string; title: string; desc: string; img: string; }
interface Props { tabs?: Tab[]; }

const CLD = 'https://res.cloudinary.com/deunehrew/image/fetch/f_auto,q_auto,w_800/https://d8j0ntlcm91z4.cloudfront.net/';
const {
  tabs = [
    { key: 'energy', label: 'Energy', title: 'Lower energy bills', desc: 'Reject solar heat and cut cooling costs year-round.', img: CLD + 'hf_20260617_2053_energy.png' },
    { key: 'uv', label: 'UV', title: '99% UV protection', desc: 'Protect skin and prevent fading of floors and furniture.', img: CLD + 'hf_20260617_2053_uv.png' },
    { key: 'privacy', label: 'Privacy', title: 'Daytime privacy', desc: 'See out without others seeing in.', img: CLD + 'hf_20260617_2053_privacy.png' },
    { key: 'glare', label: 'Glare', title: 'Glare reduction', desc: 'Work and relax without harsh glare on screens.', img: CLD + 'hf_20260617_2053_glare.png' },
    { key: 'graffiti', label: 'Graffiti', title: 'Anti-graffiti', desc: 'Sacrificial film protects glass from etching and tags.', img: CLD + 'hf_20260617_2053_graffiti.png' },
    { key: 'safety', label: 'Safety', title: 'Safety & security', desc: 'Holds shattered glass together on impact.', img: CLD + 'hf_20260617_2053_safety.png' },
    { key: 'decorative', label: 'Decorative', title: 'Decorative film', desc: 'Frosted, patterned, and branded finishes.', img: CLD + 'hf_20260617_2053_decorative.png' },
    { key: 'solar', label: 'Solar', title: 'Solar control', desc: 'Balance light and heat for total comfort.', img: CLD + 'hf_20260617_2053_solar.png' },
  ],
} = Astro.props;
---

<section class="benefits-new bg-ink py-16">
  <div class="mx-auto max-w-6xl px-6">
    <h2 class="mb-8 text-center font-display text-3xl font-bold text-white sm:text-4xl">Benefits of window film</h2>

    <!-- tabs -->
    <div class="mb-8 flex flex-wrap justify-center gap-2">
      {tabs.map((t, i) => (
        <button class={`benefits-new__tab rounded-full border px-4 py-2 text-sm font-semibold ${i === 0 ? 'border-brand bg-brand text-white' : 'border-white/15 text-white/70'}`} data-tab={t.key}>{t.label}</button>
      ))}
    </div>

    <!-- panels -->
    <div class="relative">
      {tabs.map((t, i) => (
        <div class={`benefits-new__panel grid gap-8 md:grid-cols-2 ${i === 0 ? '' : 'hidden'}`} data-panel={t.key}>
          <div class="benefits-new__image-set overflow-hidden rounded-2xl">
            <img src={t.img} alt={t.title} class="h-72 w-full object-cover md:h-full" loading="lazy" />
          </div>
          <div class="flex flex-col justify-center">
            <h3 class="font-display text-2xl font-bold text-white">{t.title}</h3>
            <p class="mt-3 text-white/70">{t.desc}</p>
            <a href="/contact/" class="mt-6 inline-block w-fit rounded-full bg-brand px-6 py-2.5 font-semibold text-white transition hover:bg-brand-dark">Get a free quote</a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .benefits-new__image-set { transition: opacity 0.3s ease, visibility 0.3s ease; }
  .benefits-new__tab { transition: all 0.2s ease; }
</style>

<script>
  const section = document.querySelector<HTMLElement>('.benefits-new');
  if (section) {
    const tabs = Array.from(section.querySelectorAll<HTMLElement>('.benefits-new__tab'));
    const panels = Array.from(section.querySelectorAll<HTMLElement>('.benefits-new__panel'));
    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const key = tab.dataset.tab;
        tabs.forEach((t) => {
          const on = t === tab;
          t.classList.toggle('border-brand', on);
          t.classList.toggle('bg-brand', on);
          t.classList.toggle('text-white', on);
          t.classList.toggle('border-white/15', !on);
          t.classList.toggle('text-white/70', !on);
        });
        panels.forEach((p) => p.classList.toggle('hidden', p.dataset.panel !== key));
      });
    });
  }
</script>
