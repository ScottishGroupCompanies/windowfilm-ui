---
// ProcessRoadmap.astro
// A winding route that draws itself as you scroll, connecting the 4 steps of
// the service process (Consultation → Measurement → Installation → Warranty).
// Each milestone pops in when the path reaches it. Inspired by the animated
// roadmap reference, rebuilt with IntersectionObserver + scroll-driven dash.
//
// HOW TO USE:
//   <ProcessRoadmap />
//   Steps are props: { title, desc } — the path + marker positions are fixed.

interface Step { title: string; desc: string; }
interface Props { heading?: string; sub?: string; steps?: Step[]; }
const {
  heading = 'How it works',
  sub = 'From first call to lifetime warranty — a simple, proven process.',
  steps = [
    { title: 'Consultation', desc: 'Free assessment of your glass, goals, and budget.' },
    { title: 'Measurement', desc: 'Precise measurements and film selection for each pane.' },
    { title: 'Installation', desc: 'Clean, professional install by our certified team.' },
    { title: 'Warranty', desc: 'Backed for life — we stand behind every project.' },
  ],
} = Astro.props;

// fixed marker anchor points along the path (viewBox 0 0 800 360)
const anchors = [ {x:70,y:290}, {x:300,y:110}, {x:520,y:250}, {x:740,y:90} ];
---

<section class="prm">
  <div class="prm__head">
    <h2 class="prm__title font-display">{heading}</h2>
    <p class="prm__sub">{sub}</p>
  </div>

  <div class="prm__stage">
    <svg viewBox="0 0 800 360" class="prm__svg" preserveAspectRatio="none" aria-hidden="true">
      <path class="prm__track" d="M 70 290 Q 180 90 300 110 T 520 250 T 740 90" fill="none" stroke="rgba(255,255,255,0.1)" stroke-width="3" stroke-linecap="round" stroke-dasharray="8 8" />
      <path class="prm__progress" d="M 70 290 Q 180 90 300 110 T 520 250 T 740 90" fill="none" stroke="var(--brand-green)" stroke-width="3.5" stroke-linecap="round" />
    </svg>

    {steps.map((s, i) => (
      <div class="prm__milestone" style={`--i:${i}; left:${(anchors[i]?.x ?? 0) / 800 * 100}%; top:${(anchors[i]?.y ?? 0) / 360 * 100}%;`}>
        <span class="prm__dot"><span class="prm__num">{i + 1}</span></span>
        <div class="prm__card">
          <h3>{s.title}</h3>
          <p>{s.desc}</p>
        </div>
      </div>
    ))}
  </div>
</section>

<style is:global>
  .prm { background: var(--ink, #0d1b2a); padding: 4rem 1.5rem; }
  .prm__head { max-width: 42rem; margin: 0 auto 2rem; text-align: center; }
  .prm__title { color: #fff; font-size: clamp(1.6rem, 3.5vw, 2.4rem); font-weight: 700; margin: 0 0 0.5rem; }
  .prm__sub { color: rgba(255,255,255,0.5); margin: 0; }

  .prm__stage { position: relative; max-width: 60rem; margin: 0 auto; aspect-ratio: 800/360; }
  .prm__svg { position: absolute; inset: 0; width: 100%; height: 100%; }
  .prm__progress {
    stroke-dasharray: var(--len, 1200);
    stroke-dashoffset: var(--len, 1200);
    transition: stroke-dashoffset 1.4s ease;
  }
  .prm.is-visible .prm__progress { stroke-dashoffset: 0; }

  .prm__milestone { position: absolute; transform: translate(-50%, -50%); display: flex; flex-direction: column; align-items: center; gap: 0.6rem; width: 160px; }
  .prm__dot {
    width: 40px; height: 40px; border-radius: 9999px;
    background: var(--brand-green); color: var(--ink, #0d1b2a);
    display: flex; align-items: center; justify-content: center;
    font-weight: 800; border: 3px solid var(--ink, #0d1b2a);
    box-shadow: 0 0 0 3px var(--brand-green);
    opacity: 0; transform: scale(0.4);
    transition: opacity 0.4s ease, transform 0.4s cubic-bezier(0.34,1.56,0.64,1);
    transition-delay: calc(var(--i) * 0.35s + 0.4s);
  }
  .prm.is-visible .prm__dot { opacity: 1; transform: scale(1); }
  .prm__card {
    background: var(--slate, #12293f); border: 1px solid rgba(255,255,255,0.1);
    border-radius: 0.75rem; padding: 0.75rem 0.9rem; text-align: center;
    opacity: 0; transform: translateY(8px);
    transition: opacity 0.4s ease, transform 0.4s ease;
    transition-delay: calc(var(--i) * 0.35s + 0.55s);
  }
  .prm.is-visible .prm__card { opacity: 1; transform: translateY(0); }
  .prm__card h3 { color: #fff; font-family: Georgia, serif; font-size: 0.98rem; margin: 0 0 0.2rem; }
  .prm__card p { color: rgba(255,255,255,0.55); font-size: 0.76rem; line-height: 1.45; margin: 0; }

  @media (max-width: 720px) {
    .prm__stage { aspect-ratio: auto; height: auto; display: flex; flex-direction: column; gap: 1rem; }
    .prm__svg { display: none; }
    .prm__milestone { position: static; transform: none; width: 100%; flex-direction: row; text-align: left; }
    .prm__card { text-align: left; flex: 1; }
  }
  @media (prefers-reduced-motion: reduce) {
    .prm__progress { stroke-dashoffset: 0; transition: none; }
    .prm__dot, .prm__card { opacity: 1; transform: none; }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('.prm').forEach((root) => {
    const prog = root.querySelector<SVGPathElement>('.prm__progress');
    if (prog) { const len = prog.getTotalLength(); root.style.setProperty('--len', String(len)); }
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => { if (e.isIntersecting) { root.classList.add('is-visible'); io.unobserve(root); } });
    }, { threshold: 0.35 });
    io.observe(root);
  });
</script>
