---
// TeamSpotlightCarousel.astro
// One large "spotlight" profile (photo + full bio) with a row of clickable
// thumbnails below to switch between team members. Feels personal — good
// for an "our leadership" or "meet the team" moment where you want visitors
// to actually read the bios instead of skimming a grid. Vanilla JS.
//
// HOW TO USE:
//   <TeamSpotlightCarousel />   (uses the shared 8 team members)

import { team as shared, type TeamMember } from '../data/team';

interface Props { heading?: string; sub?: string; members?: TeamMember[]; }
const {
  heading = 'Meet the team',
  sub = 'One point of contact from quote to final walkthrough.',
  members = shared,
} = Astro.props;
---

<section class="tsc">
  <div class="tsc__head">
    <h2 class="tsc__title font-display">{heading}</h2>
    <p class="tsc__sub">{sub}</p>
  </div>

  <div class="tsc__stage">
    {members.map((m, i) => (
      <div class={`tsc__panel ${i === 0 ? 'is-active' : ''}`} data-panel={i}>
        <div class="tsc__photo"><img src={m.photo} alt={m.name} loading="lazy" /></div>
        <div class="tsc__info">
          <h3>{m.name}</h3>
          <p class="tsc__role">{m.role}</p>
          <p class="tsc__bio">{m.bio}</p>
        </div>
      </div>
    ))}
  </div>

  <div class="tsc__thumbs">
    {members.map((m, i) => (
      <button class={`tsc__thumb ${i === 0 ? 'is-active' : ''}`} data-thumb={i} aria-label={m.name}>
        <img src={m.photo} alt="" loading="lazy" />
      </button>
    ))}
  </div>
</section>

<style is:global>
  .tsc { background: var(--ink, #0d1b2a); padding: 4rem 1.5rem; }
  .tsc__head { max-width: 40rem; margin: 0 auto 2.5rem; text-align: center; }
  .tsc__title { color: #fff; font-size: clamp(1.6rem, 3.5vw, 2.4rem); font-weight: 700; margin: 0 0 0.5rem; }
  .tsc__sub { color: rgba(255,255,255,0.5); margin: 0; }

  .tsc__stage { position: relative; max-width: 52rem; margin: 0 auto 1.75rem; min-height: 320px; }
  .tsc__panel {
    position: absolute; inset: 0;
    display: grid; grid-template-columns: 220px 1fr; gap: 2rem; align-items: center;
    opacity: 0; visibility: hidden; transform: translateY(10px);
    transition: opacity 0.4s ease, transform 0.4s ease;
  }
  .tsc__panel.is-active { opacity: 1; visibility: visible; transform: translateY(0); }
  .tsc__photo { aspect-ratio: 1; border-radius: 1.1rem; overflow: hidden; border: 2px solid rgba(124,179,66,0.4); }
  .tsc__photo img { width: 100%; height: 100%; object-fit: cover; }
  .tsc__info h3 { color: #fff; font-family: Georgia, serif; font-size: 1.6rem; margin: 0 0 0.3rem; }
  .tsc__role { color: var(--brand-green); font-size: 0.85rem; font-weight: 600; margin: 0 0 1rem; }
  .tsc__bio { color: rgba(255,255,255,0.6); font-size: 0.95rem; line-height: 1.65; margin: 0; }

  .tsc__thumbs { display: flex; justify-content: center; gap: 0.6rem; flex-wrap: wrap; }
  .tsc__thumb {
    width: 52px; height: 52px; border-radius: 9999px; overflow: hidden;
    border: 2.5px solid transparent; padding: 0; cursor: pointer;
    opacity: 0.5; transition: opacity 0.25s ease, border-color 0.25s ease, transform 0.25s ease;
  }
  .tsc__thumb img { width: 100%; height: 100%; object-fit: cover; }
  .tsc__thumb:hover { opacity: 0.85; transform: translateY(-2px); }
  .tsc__thumb.is-active { opacity: 1; border-color: var(--brand-green); }

  @media (max-width: 640px) {
    .tsc__panel { grid-template-columns: 1fr; text-align: center; }
    .tsc__photo { width: 140px; margin: 0 auto; }
  }
  @media (prefers-reduced-motion: reduce) { .tsc__panel { transition: none; } }
</style>

<script>
  document.querySelectorAll<HTMLElement>('.tsc').forEach((root) => {
    const thumbs = Array.from(root.querySelectorAll<HTMLElement>('.tsc__thumb'));
    const panels = Array.from(root.querySelectorAll<HTMLElement>('.tsc__panel'));
    thumbs.forEach((thumb) => {
      thumb.addEventListener('click', () => {
        const idx = thumb.getAttribute('data-thumb');
        thumbs.forEach((t) => t.classList.remove('is-active'));
        panels.forEach((p) => p.classList.remove('is-active'));
        thumb.classList.add('is-active');
        panels.find((p) => p.getAttribute('data-panel') === idx)?.classList.add('is-active');
      });
    });
  });
</script>
