---
// BlogPostTOC.astro
// A single blog post with a sticky Table of Contents sidebar (scroll-spy
// highlights the active section) and a reading-progress bar at the top.
// Best for long SEO guides. The TOC is generated from the sections prop; the
// body is passed via <slot> with matching id headings. Reads meta from props.
//
// HOW TO USE:
//   <BlogPostTOC post={posts[1]} sections={[{id:'intro',label:'Introduction'}]}>
//     <h2 id="intro">Introduction</h2> ...
//   </BlogPostTOC>
//   With no slot, a sample article + TOC is shown.

import { posts, type BlogPost } from '../data/posts';

interface Section { id: string; label: string; }
interface Props { post?: BlogPost; sections?: Section[]; }
const {
  post = posts[1],
  sections = [
    { id: 'intro', label: 'Introduction' },
    { id: 'heat', label: 'The heat problem' },
    { id: 'choosing', label: 'Choosing a film' },
    { id: 'verdict', label: 'The verdict' },
  ],
} = Astro.props;
---

<article class="ptoc">
  <div class="ptoc__progress" aria-hidden="true"><span class="ptoc__progress-bar"></span></div>

  <div class="ptoc__hero"><img src={post.hero} alt={post.title} /></div>

  <div class="ptoc__container">
    <header class="ptoc__header">
      <span class="ptoc__chip">{post.category}</span>
      <h1 class="ptoc__title font-display">{post.title}</h1>
      <div class="ptoc__byline">
        <img src={post.author.avatar} alt={post.author.name} />
        <span><b>{post.author.name}</b><small>{post.date} · {post.readMins} min read</small></span>
      </div>
    </header>

    <div class="ptoc__layout">
      <aside class="ptoc__toc">
        <p class="ptoc__toc-title">On this page</p>
        <nav>
          {sections.map((sxn) => (
            <a href={`#${sxn.id}`} class="ptoc__toc-link" data-toc={sxn.id}>{sxn.label}</a>
          ))}
        </nav>
      </aside>

      <div class="ptoc__body">
        <slot>
          <h2 id="intro">Introduction</h2>
          <p>West-facing windows take the brunt of the afternoon sun — the harshest heat and glare of the day. If a room gets uncomfortable after lunch, the orientation of its glass is usually the reason.</p>
          <h2 id="heat">The heat problem</h2>
          <p>Late-day sun hits west glass at a low angle, pouring solar energy directly into the room. Standard glass does almost nothing to stop it, which is why these rooms overheat and fade fastest.</p>
          <blockquote>"West-facing glass is where a good solar film makes the most dramatic difference — often a 10–15°F swing."</blockquote>
          <h2 id="choosing">Choosing a film</h2>
          <ul>
            <li><strong>Spectrally selective film</strong> — rejects heat while staying clear.</li>
            <li><strong>Dual-reflective film</strong> — daytime privacy plus strong heat control.</li>
            <li><strong>Ceramic film</strong> — top-tier performance, no signal interference.</li>
          </ul>
          <h2 id="verdict">The verdict</h2>
          <p>For most west-facing rooms, a quality spectrally selective or ceramic film is the sweet spot — big comfort gains without darkening the space. A quick on-site assessment will confirm the right choice.</p>
        </slot>
      </div>
    </div>
  </div>
</article>

<style is:global>
  .ptoc { background: var(--ink, #0d1b2a); padding-bottom: 4rem; position: relative; }
  .ptoc__progress { position: sticky; top: 0; left: 0; height: 3px; background: rgba(255,255,255,0.08); z-index: 30; }
  .ptoc__progress-bar { display: block; height: 100%; width: 0%; background: var(--brand-green); transition: width 0.1s linear; }

  .ptoc__hero { width: 100%; aspect-ratio: 21/9; overflow: hidden; }
  .ptoc__hero img { width: 100%; height: 100%; object-fit: cover; }
  .ptoc__container { max-width: 60rem; margin: 0 auto; padding: 0 1.5rem; }

  .ptoc__header { text-align: center; margin: -3rem auto 2.5rem; }
  .ptoc__chip { display: inline-block; background: var(--brand-green); color: var(--ink, #0d1b2a); font-size: 0.68rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; padding: 0.3rem 0.75rem; border-radius: 9999px; margin-bottom: 1rem; }
  .ptoc__title { color: #fff; font-size: clamp(1.9rem, 4vw, 2.8rem); line-height: 1.12; font-weight: 800; margin: 0 0 1.25rem; }
  .ptoc__byline { display: inline-flex; align-items: center; gap: 0.65rem; }
  .ptoc__byline img { width: 42px; height: 42px; border-radius: 9999px; object-fit: cover; border: 2px solid var(--brand-green); }
  .ptoc__byline b { display: block; color: #fff; font-size: 0.9rem; text-align: left; }
  .ptoc__byline small { color: rgba(255,255,255,0.5); font-size: 0.78rem; }

  .ptoc__layout { display: grid; grid-template-columns: 200px 1fr; gap: 3rem; align-items: start; }
  .ptoc__toc { position: sticky; top: 2rem; }
  .ptoc__toc-title { color: rgba(255,255,255,0.4); font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.14em; margin: 0 0 0.75rem; }
  .ptoc__toc nav { display: flex; flex-direction: column; gap: 0.15rem; border-left: 1px solid rgba(255,255,255,0.1); }
  .ptoc__toc-link { padding: 0.4rem 0 0.4rem 1rem; margin-left: -1px; border-left: 2px solid transparent; color: rgba(255,255,255,0.5); font-size: 0.85rem; text-decoration: none; transition: color 0.2s, border-color 0.2s; }
  .ptoc__toc-link:hover { color: #fff; }
  .ptoc__toc-link.toc-active { color: #fff; border-left-color: var(--brand-green); }

  .ptoc__body { color: rgba(255,255,255,0.75); font-size: 1.05rem; line-height: 1.75; min-width: 0; }
  .ptoc__body h2 { color: #fff; font-family: Georgia, serif; font-size: 1.55rem; margin: 2.25rem 0 0.75rem; scroll-margin-top: 2rem; }
  .ptoc__body h2:first-child { margin-top: 0; }
  .ptoc__body p { margin: 0 0 1.15rem; }
  .ptoc__body ul { margin: 0 0 1.15rem; padding-left: 1.25rem; }
  .ptoc__body li { margin-bottom: 0.5rem; }
  .ptoc__body li::marker { color: var(--brand-green); }
  .ptoc__body strong { color: #fff; }
  .ptoc__body blockquote { margin: 1.75rem 0; padding: 1rem 1.5rem; border-left: 3px solid var(--brand-green); background: rgba(124,179,66,0.08); color: #fff; font-family: Georgia, serif; font-size: 1.18rem; font-style: italic; border-radius: 0 0.5rem 0.5rem 0; }

  @media (max-width: 820px) {
    .ptoc__layout { grid-template-columns: 1fr; gap: 1.5rem; }
    .ptoc__toc { position: static; }
    .ptoc__toc nav { flex-direction: row; flex-wrap: wrap; border-left: none; gap: 0.5rem; }
    .ptoc__toc-link { border: 1px solid rgba(255,255,255,0.15); border-radius: 9999px; padding: 0.3rem 0.8rem; margin: 0; }
    .ptoc__toc-link.toc-active { border-color: var(--brand-green); }
  }
  @media (prefers-reduced-motion: reduce) { .ptoc__progress-bar { transition: none; } }
</style>

<script>
  document.querySelectorAll('.ptoc').forEach((root) => {
    // reading progress
    const bar = root.querySelector('.ptoc__progress-bar');
    const body = root.querySelector('.ptoc__body');
    function onScroll() {
      if (!bar || !body) return;
      const rect = body.getBoundingClientRect();
      const total = rect.height - window.innerHeight;
      const scrolled = Math.min(Math.max(-rect.top, 0), Math.max(total, 1));
      bar.style.width = (total > 0 ? (scrolled / total) * 100 : 0) + '%';
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    // scroll-spy for TOC
    const links = new Map();
    root.querySelectorAll('.ptoc__toc-link').forEach((l) => links.set(l.getAttribute('data-toc'), l));
    const io = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        root.querySelectorAll('.ptoc__toc-link').forEach((l) => l.classList.remove('toc-active'));
        links.get(entry.target.id)?.classList.add('toc-active');
      });
    }, { rootMargin: '-10% 0px -80% 0px' });
    root.querySelectorAll('.ptoc__body h2[id]').forEach((h) => io.observe(h));
  });
</script>
