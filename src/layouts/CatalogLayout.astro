---
// CatalogLayout.astro — base structure of the catalog page.
interface Props { title?: string; }
const { title = 'SWF Components — Window Film UI' } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex" />
    <title>{title}</title>
    <!-- Brand fonts: Fraunces (display) + Inter (body) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400..900&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style is:global>
      /* Single source of truth for the brand green. Change here → everywhere. */
      :root {
        --brand-green: #7CB342;
        --brand-green-light: #8fc756;
        --ink: #0d1b2a;
        --slate: #12293f;
        --cream: #ece9e4;
      }
      /* Sidebar scroll-spy active state */
      .spy-link.spy-active {
        color: #fff;
        border-left-color: var(--brand-green);
        background: rgba(124,179,66,0.08);
      }
    </style>
  </head>
  <body class="bg-slate font-body text-white antialiased">
    <slot />

    <script>
      // Copy to clipboard for any .copy-btn button.
      // Supports data-code (single block) and "copy all" buttons that carry
      // both the import and usage in data-code-all.
      document.querySelectorAll('.copy-btn').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const code = btn.getAttribute('data-code-all') ?? btn.getAttribute('data-code') ?? '';
          try {
            await navigator.clipboard.writeText(code);
            const original = btn.textContent;
            btn.textContent = 'Copied!';
            setTimeout(() => { btn.textContent = original; }, 1500);
          } catch {
            btn.textContent = 'Error';
          }
        });
      });

      // Scroll-spy: highlight the sidebar link of the section in view.
      const spyLinks = document.querySelectorAll('.spy-link');
      if (spyLinks.length) {
        const byId = new Map();
        spyLinks.forEach((l) => byId.set(l.getAttribute('data-spy'), l));
        const spyObserver = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            spyLinks.forEach((l) => l.classList.remove('spy-active'));
            const link = byId.get(entry.target.id);
            if (link) {
              link.classList.add('spy-active');
              link.scrollIntoView({ block: 'nearest' });
            }
          });
        }, { rootMargin: '-20% 0px -70% 0px', threshold: 0 });
        document.querySelectorAll('section[id]').forEach((s) => spyObserver.observe(s));
      }
    </script>
  </body>
</html>
