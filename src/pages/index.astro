---
import CatalogLayout from '../layouts/CatalogLayout.astro';
import ElementShowcase from '../components/catalog/ElementShowcase.astro';

// Signature (industry-specific, highest impact)
import BeforeAfterSlider from '../components/BeforeAfterSlider.astro';
import FolderGallery from '../components/FolderGallery.astro';
import GalleryBanner from '../components/GalleryBanner.astro';

// Testimonials
import TestimonialStack from '../components/TestimonialStack.astro';
import TestimonialMarquee from '../components/TestimonialMarquee.astro';
import TestimonialSpotlight from '../components/TestimonialSpotlight.astro';

// Navbars
import NavbarMegaImage from '../components/NavbarMegaImage.astro';
import NavbarMegaIcon from '../components/NavbarMegaIcon.astro';
import NavbarGlassPill from '../components/NavbarGlassPill.astro';

// Logo Clouds
import LogoCloudBlurFlip from '../components/LogoCloudBlurFlip.astro';
import LogoCloudSpotlight from '../components/LogoCloudSpotlight.astro';
import LogoCloudSwap from '../components/LogoCloudSwap.astro';

// Bento Grids
import BentoGridPhoto from '../components/BentoGridPhoto.astro';
import BentoGridSymmetric from '../components/BentoGridSymmetric.astro';
import BentoGridIllustrated from '../components/BentoGridIllustrated.astro';

// CTA Sections
import CTAAvatars from '../components/CTAAvatars.astro';
import CTATintSlider from '../components/CTATintSlider.astro';
import CTALightRays from '../components/CTALightRays.astro';

// Elements
import HeroVideo from '../components/HeroVideo.astro';
import HeroSubpage from '../components/HeroSubpage.astro';
import TrustStrip from '../components/TrustStrip.astro';
import WhatWeDoPanels from '../components/WhatWeDoPanels.astro';
import HowItWorksSlideshow from '../components/HowItWorksSlideshow.astro';
import ApplicationsGrid from '../components/ApplicationsGrid.astro';
import BenefitsTabs from '../components/BenefitsTabs.astro';
import ReviewsCarousel from '../components/ReviewsCarousel.astro';
import VideoBand from '../components/VideoBand.astro';

// Animations
import CountUp from '../components/animations/CountUp.astro';
import ScrollReveal from '../components/animations/ScrollReveal.astro';
import WordStagger from '../components/animations/WordStagger.astro';
import FadeInUp from '../components/animations/FadeInUp.astro';

// Text Animations
import SplitTextReveal from '../components/animations/SplitTextReveal.astro';
import GradientText from '../components/animations/GradientText.astro';
import Typewriter from '../components/animations/Typewriter.astro';
import TextScramble from '../components/animations/TextScramble.astro';
import LineMaskReveal from '../components/animations/LineMaskReveal.astro';
import HandDrawnTitle from '../components/animations/HandDrawnTitle.astro';
import TextLoop from '../components/animations/TextLoop.astro';
import ShinyText from '../components/animations/ShinyText.astro';

const signatureNav = [
  { id: 'beforeafterslider', label: 'Before / After Slider' },
  { id: 'foldergallery', label: 'Folder Gallery' },
  { id: 'gallerybanner', label: 'Gallery Banner' },
];
const testimonialNav = [
  { id: 'testimonialstack', label: 'Testimonial Stack' },
  { id: 'testimonialmarquee', label: 'Testimonial Marquee' },
  { id: 'testimonialspotlight', label: 'Testimonial Spotlight' },
];
const navbarNav = [
  { id: 'navbarmegaimage', label: 'Navbar — Mega Image' },
  { id: 'navbarmegaicon', label: 'Navbar — Mega Icon' },
  { id: 'navbarglasspill', label: 'Navbar — Glass Pill' },
];
const logoNav = [
  { id: 'logocloudblurflip', label: 'Logo Cloud — Blur Flip' },
  { id: 'logocloudspotlight', label: 'Logo Cloud — Spotlight' },
  { id: 'logocloudswap', label: 'Logo Cloud — Swap' },
];
const bentoNav = [
  { id: 'bentogridphoto', label: 'Bento — Photo' },
  { id: 'bentogridsymmetric', label: 'Bento — Symmetric' },
  { id: 'bentogridillustrated', label: 'Bento — Illustrated' },
];
const ctaNav = [
  { id: 'ctaavatars', label: 'CTA — Avatars' },
  { id: 'ctatintslider', label: 'CTA — Tint Slider' },
  { id: 'ctalightrays', label: 'CTA — Light Rays' },
];
const elementNav = [
  { id: 'herovideo', label: 'Hero Video' },
  { id: 'herosubpage', label: 'Hero Subpage' },
  { id: 'truststrip', label: 'Trust Strip' },
  { id: 'whatwedopanels', label: 'What We Do Panels' },
  { id: 'howitworksslideshow', label: 'How It Works Slideshow' },
  { id: 'applicationsgrid', label: 'Applications Grid' },
  { id: 'benefitstabs', label: 'Benefits Tabs' },
  { id: 'reviewscarousel', label: 'Reviews Carousel' },
  { id: 'videoband', label: 'Video Band' },
  { id: 'mobilestickycta', label: 'Mobile Sticky CTA' },
];
const animationNav = [
  { id: 'countup', label: 'Count Up' },
  { id: 'scrollreveal', label: 'Scroll Reveal' },
  { id: 'wordstagger', label: 'Word Stagger' },
  { id: 'fadeinup', label: 'Fade In Up' },
];
const textNav = [
  { id: 'splittextreveal', label: 'Split Text Reveal' },
  { id: 'linemaskreveal', label: 'Line Mask Reveal' },
  { id: 'gradienttext', label: 'Gradient Text' },
  { id: 'typewriter', label: 'Typewriter' },
  { id: 'textscramble', label: 'Text Scramble' },
  { id: 'handdrawntitle', label: 'Hand Drawn Title' },
  { id: 'textloop', label: 'Text Loop' },
  { id: 'shinytext', label: 'Shiny Text' },
];

// Grouped structure for the redesigned sidebar (icon + count per category).
// Icons are inline SVG paths (stroke, currentColor) — no icon library.
const ICON = {
  signature: '<path d="M12 2l2.4 7.4H22l-6 4.6 2.3 7.4-6.3-4.6L5.7 21.4 8 14 2 9.4h7.6z"/>',
  testimonials: '<path d="M21 11.5a8.5 8.5 0 0 1-8.5 8.5H7l-4 3v-4.5A8.5 8.5 0 1 1 21 11.5z"/>',
  navbars: '<rect x="3" y="5" width="18" height="4" rx="1"/><rect x="3" y="13" width="12" height="4" rx="1"/>',
  logos: '<circle cx="7" cy="8" r="3"/><circle cx="17" cy="8" r="3"/><circle cx="12" cy="16" r="3"/>',
  elements: '<rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>',
  animations: '<path d="M12 2v4M12 18v4M2 12h4M18 12h4M5 5l3 3M16 16l3 3M19 5l-3 3M8 16l-3 3"/>',
  text: '<path d="M4 6h16M4 6V4h16v2M9 20h6M12 6v14"/>',
  cta: '<path d="M5 12h14M13 6l6 6-6 6"/>',
};

const categories = [
  { key: 'signature', label: 'Signature', icon: ICON.signature, items: signatureNav },
  { key: 'testimonials', label: 'Testimonials', icon: ICON.testimonials, items: testimonialNav },
  { key: 'navbars', label: 'Navbars', icon: ICON.navbars, items: navbarNav },
  { key: 'logos', label: 'Logo Clouds', icon: ICON.logos, items: logoNav },
  { key: 'bento', label: 'Bento Grids', icon: ICON.elements, items: bentoNav },
  { key: 'cta', label: 'CTA Sections', icon: ICON.cta, items: ctaNav },
  { key: 'elements', label: 'Elements', icon: ICON.elements, items: elementNav },
  { key: 'animations', label: 'Animations', icon: ICON.animations, items: animationNav },
  { key: 'text', label: 'Text Animations', icon: ICON.text, items: textNav },
];

const totalComponents = categories.reduce((n, c) => n + c.items.length, 0);
const totalCategories = categories.length;
---

<CatalogLayout>
  <!-- FIXED TOP BAR -->
  <div class="sticky top-0 z-40 border-b border-white/10 bg-ink/80 backdrop-blur-md">
    <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-3">
      <a href="#top" class="flex items-center gap-2.5">
        <span class="flex h-7 w-7 items-center justify-center rounded-md bg-brand text-ink">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/></svg>
        </span>
        <span class="font-display text-lg font-bold text-white">SWF Components</span>
      </a>
      <nav class="flex items-center gap-5 text-sm">
        <a href="#components" class="hidden text-white/60 transition hover:text-white sm:block">Components</a>
        <a href="https://windowfilmphiladelphia.net" target="_blank" rel="noopener" class="rounded-full bg-brand px-4 py-1.5 font-semibold text-ink transition hover:bg-brand-light">Live site ↗</a>
      </nav>
    </div>
  </div>

  <!-- HERO -->
  <header id="top" class="relative overflow-hidden border-b border-white/10 bg-ink">
    <!-- dot grid + ambient green glow -->
    <div class="pointer-events-none absolute inset-0" aria-hidden="true">
      <div class="absolute inset-0" style="background-image: radial-gradient(rgba(255,255,255,0.07) 1px, transparent 1px); background-size: 24px 24px; mask-image: radial-gradient(ellipse 70% 60% at 50% 40%, black, transparent);"></div>
      <div class="absolute left-1/2 top-0 h-72 w-72 -translate-x-1/2 rounded-full bg-brand/20 blur-[100px]"></div>
    </div>
    <div class="relative mx-auto max-w-6xl px-6 py-20 text-center">
      <p class="mb-4 inline-flex items-center gap-2 rounded-full border border-brand/30 bg-brand/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-brand-light">
        <span class="h-1.5 w-1.5 rounded-full bg-brand"></span> Window Film Component Library
      </p>
      <h1 class="mx-auto max-w-3xl font-display text-5xl font-black leading-[1.05] text-white sm:text-6xl">
        Premium UI blocks for <span class="text-brand-light">window film</span> websites.
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg text-white/60">
        A curated bank of animated, copy-paste components — built in Astro + Tailwind, zero dependencies.
        See each one live, then copy it straight into your page.
      </p>
      <div class="mt-8 flex items-center justify-center gap-6 text-sm">
        <div class="flex items-center gap-2"><span class="font-display text-2xl font-bold text-brand-light">{totalComponents}</span><span class="text-white/50">components</span></div>
        <span class="h-8 w-px bg-white/15"></span>
        <div class="flex items-center gap-2"><span class="font-display text-2xl font-bold text-brand-light">{totalCategories}</span><span class="text-white/50">categories</span></div>
        <span class="h-8 w-px bg-white/15"></span>
        <div class="flex items-center gap-2"><span class="font-display text-2xl font-bold text-brand-light">0</span><span class="text-white/50">dependencies</span></div>
      </div>
      <!-- quick-jump category chips -->
      <div class="mt-10 flex flex-wrap items-center justify-center gap-2">
        {categories.map((cat) => (
          <a href={`#${cat.items[0].id}`} class="group flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.04] px-4 py-2 text-sm text-white/60 transition hover:border-brand/50 hover:bg-brand/10 hover:text-white">
            <span class="text-brand-light"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={cat.icon}></svg></span>
            {cat.label}
            <span class="rounded-full bg-white/10 px-1.5 text-[0.65rem] text-white/40 transition group-hover:bg-brand/20 group-hover:text-brand-light">{cat.items.length}</span>
          </a>
        ))}
      </div>
    </div>
  </header>

  <div id="components" class="mx-auto flex max-w-6xl gap-10 px-6 py-12">
    <!-- SIDEBAR -->
    <aside class="sticky top-16 hidden h-[calc(100vh-5rem)] w-60 shrink-0 overflow-y-auto pb-10 lg:block">
      <div class="mb-4 px-1">
        <div class="relative">
          <svg class="pointer-events-none absolute left-3 top-1/2 -translate-y-1/2 text-white/30" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-4-4"/></svg>
          <input id="catalog-search" type="text" placeholder="Search components…" autocomplete="off"
            class="w-full rounded-lg border border-white/10 bg-white/[0.04] py-2 pl-9 pr-3 text-sm text-white placeholder-white/30 outline-none transition focus:border-brand/50 focus:bg-white/[0.07]" />
        </div>
      </div>
      <p class="mb-3 px-2 text-[0.7rem] font-semibold uppercase tracking-[0.18em] text-white/30">Browse</p>
      {categories.map((cat) => (
        <div class="mb-5" data-cat-group>
          <div class="mb-1.5 flex items-center gap-2 px-2">
            <span class="flex h-5 w-5 items-center justify-center text-brand-light">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={cat.icon}></svg>
            </span>
            <span class="text-xs font-semibold uppercase tracking-[0.1em] text-white/70">{cat.label}</span>
            <span class="ml-auto rounded-full bg-white/5 px-1.5 py-0.5 text-[0.65rem] font-medium text-white/40">{cat.items.length}</span>
          </div>
          <nav class="flex flex-col gap-0.5">
            {cat.items.map((it) => (
              <a href={`#${it.id}`} data-spy={it.id} class="spy-link rounded-md border-l-2 border-transparent px-3 py-1 text-sm text-white/50 transition hover:bg-white/5 hover:text-white">{it.label}</a>
            ))}
          </nav>
        </div>
      ))}
    </aside>

    <main class="min-w-0 flex-1">

      <h2 data-section-heading class="mb-2 font-display text-lg uppercase tracking-wide text-brand-light">Signature</h2>
      <p data-section-heading class="mb-6 max-w-2xl text-sm text-white/50">
        Industry-specific, high-impact pieces. These are the ones that make the site feel
        premium instead of generic — worth using prominently on the homepage and service pages.
      </p>

      <ElementShowcase
        title="Before / After Slider"
        importAs="BeforeAfterSlider"
        file="components/BeforeAfterSlider.astro"
        usage="Drag the handle to reveal the 'after' (with film) image over the 'before' (without film) image. Works with mouse, touch, and keyboard (arrow keys). The single most persuasive visual for a window film company — it shows the transformation instead of describing it. Use real before/after photos of the same window, same angle."
        code={`<BeforeAfterSlider
  before="https://res.cloudinary.com/.../no-film.png"
  after="https://res.cloudinary.com/.../with-film.png"
  beforeLabel="Without film"
  afterLabel="With film"
/>`}
      >
        <div class="p-6">
          <BeforeAfterSlider
            before="https://res.cloudinary.com/deunehrew/image/upload/v1783021712/hf_20260702_194725_d1e28908-f22f-4b0a-b57a-cde43f0679e4_tkvrcf.png"
            after="https://res.cloudinary.com/deunehrew/image/upload/v1783021732/hf_20260702_194819_e9eb3a1d-e086-4b00-bd89-d69fe581239b_wzpeme.png"
            beforeLabel="Without film"
            afterLabel="With film"
          />
        </div>
      </ElementShowcase>

      <ElementShowcase
        title="Folder Gallery"
        importAs="FolderGallery"
        file="components/FolderGallery.astro"
        usage="Click the folder to open it — 5 photos fan out like a hand of cards. Click any photo (or hover to preview) to close it again. Works best with exactly 5 photos showing a real process: measuring, applying, squeegeeing, inspecting, finished result. Great for 'see our work' sections, more engaging than a static grid."
        code={`<FolderGallery
  folderName="Residential Installs"
  photos={[
    "https://res.cloudinary.com/.../step1.png",
    "https://res.cloudinary.com/.../step2.png",
    "https://res.cloudinary.com/.../step3.png",
    "https://res.cloudinary.com/.../step4.png",
    "https://res.cloudinary.com/.../step5.png",
  ]}
/>`}
      >
        <FolderGallery
          folderName="Residential Installs"
          photos={[
            'https://res.cloudinary.com/deunehrew/image/upload/v1783023662/hf_20260702_201720_94404319-fbd4-4490-838e-e2e772e6571a_uphqo3.png',
            'https://res.cloudinary.com/deunehrew/image/upload/v1783023672/hf_20260702_201750_55c4f4da-181e-4c45-a425-4fcd4ffdc5c5_uajwcn.png',
            'https://res.cloudinary.com/deunehrew/image/upload/v1783023687/hf_20260702_201942_67c4f492-ced2-4b95-81f7-9d9ce296e767_ywb5at.png',
            'https://res.cloudinary.com/deunehrew/image/upload/v1783023698/hf_20260702_201815_00fa5609-ece8-449f-aa81-66c2b459f189_o1dykm.png',
            'https://res.cloudinary.com/deunehrew/image/upload/v1783023709/hf_20260702_201841_873022c5-ccd1-4043-9947-576a3388e50a_gwnd08.png',
          ]}
        />
      </ElementShowcase>

      <ElementShowcase
        title="Gallery Banner"
        importAs="GalleryBanner"
        file="components/GalleryBanner.astro"
        usage="Full-width editorial banner: giant cropped typography bleeding off the left edge, supporting copy, and vertical photo strips on the right that fan apart on hover — hover a strip to expand it, click to pin it forward. Use as a 'see our work' section between page blocks. theme='light' or 'dark'. The title crop is intentional — that's the editorial look."
        code={`<GalleryBanner
  titleLines={["OUR", "WORK."]}
  eyebrow="RESIDENTIAL INSTALLS"
  description="A collection of real installations."
  photos={[
    "https://res.cloudinary.com/.../1.png",
    "https://res.cloudinary.com/.../2.png",
    "https://res.cloudinary.com/.../3.png",
    "https://res.cloudinary.com/.../4.png",
    "https://res.cloudinary.com/.../5.png",
  ]}
  theme="light"
/>`}
      >
        <GalleryBanner />
      </ElementShowcase>

      <h2 data-section-heading class="mb-2 mt-4 font-display text-lg uppercase tracking-wide text-white/40">Testimonials</h2>
      <p data-section-heading class="mb-6 max-w-2xl text-sm text-white/50">
        Three social-proof layouts sharing the same 6 real reviews (edit them once in
        <code class="text-brand-light">src/data/testimonials.ts</code>). Navy cards, green accents, serif quotes.
      </p>

      <ElementShowcase
        title="Testimonial Stack"
        importAs="TestimonialStack"
        file="components/TestimonialStack.astro"
        usage="Reviews stacked like a deck of cards. Drag the top card (or click) and it flies off to reveal the next — cycles infinitely. The most engaging option, great for a focused 'what clients say' moment. Uses the shared 6 testimonials by default."
        code={`<TestimonialStack />

<!-- or pass your own -->
<TestimonialStack items={[
  { name: 'Sarah M.', quote: '...', detail: 'Manayunk', avatar: '/images/testimonial-5.jpg' },
]} />`}
      >
        <TestimonialStack />
      </ElementShowcase>

      <ElementShowcase
        title="Testimonial Marquee"
        importAs="TestimonialMarquee"
        file="components/TestimonialMarquee.astro"
        usage="Two rows of review cards sliding in opposite directions on an infinite loop; both pause on hover. Conveys 'hundreds of happy clients' at a glance. Pure CSS, no JS. Good as a full-width band between sections."
        code={`<TestimonialMarquee />`}
      >
        <TestimonialMarquee />
      </ElementShowcase>

      <ElementShowcase
        title="Testimonial Spotlight"
        importAs="TestimonialSpotlight"
        file="components/TestimonialSpotlight.astro"
        usage="A wall of review cards where a soft green spotlight follows the cursor and lights the card underneath. Interactive and alive — best for a dedicated reviews page. Move your mouse across the cards."
        code={`<TestimonialSpotlight />`}
      >
        <TestimonialSpotlight />
      </ElementShowcase>

      <h2 data-section-heading class="mb-2 mt-4 font-display text-lg uppercase tracking-wide text-white/40">Navbars</h2>
      <p data-section-heading class="mb-6 max-w-2xl text-sm text-white/50">
        Three navigation styles using the real WFP menu (Services · Applications · Benefits · Products · About)
        with the green "Get a Free Quote" CTA. Hover the items to see the menus and the sliding pill.
      </p>

      <ElementShowcase
        title="Navbar — Mega Image"
        importAs="NavbarMegaImage"
        file="components/NavbarMegaImage.astro"
        tall={true}
        usage="Floating pill navbar. Hover 'Services' to open an image mega-menu (Residential / Commercial / Government / Specialty) using the real category photos. Best for the main site nav where you want to show the services visually."
        code={`<NavbarMegaImage />

<!-- customize items + cards -->
<NavbarMegaImage
  items={[{ label: 'Services', href: '/services/', cards: [
    { title: 'Residential', desc: '...', img: '...', href: '/services/residential/' },
  ]}]}
/>`}
      >
        <NavbarMegaImage />
      </ElementShowcase>

      <ElementShowcase
        title="Navbar — Mega Icon"
        importAs="NavbarMegaIcon"
        file="components/NavbarMegaIcon.astro"
        tall={true}
        usage="Navbar with an icon mega-menu. Hover 'Benefits' to open a compact grid of items (icon + title + short description) — ideal for long menus like Benefits (many items) where images would be too heavy. Inline SVG icons, no icon library."
        code={`<NavbarMegaIcon />`}
      >
        <NavbarMegaIcon />
      </ElementShowcase>

      <ElementShowcase
        title="Navbar — Glass Pill"
        importAs="NavbarGlassPill"
        file="components/NavbarGlassPill.astro"
        usage="Frosted-glass navbar (glassmorphism — it literally looks like window film) with a green pill that slides to the hovered/active item on a spring curve. No mega-menu — for simple inner pages. Hover the items to see the pill move."
        code={`<NavbarGlassPill active={0} />`}
      >
        <NavbarGlassPill />
      </ElementShowcase>

      <h2 data-section-heading class="mb-2 mt-4 font-display text-lg uppercase tracking-wide text-white/40">Logo Clouds</h2>
      <p data-section-heading class="mb-6 max-w-2xl text-sm text-white/50">
        Three ways to show the film brands you install (3M, LLumar, Vista…), all using the real logos in
        <code class="text-brand-light">public/images/</code> and a shared list in <code class="text-brand-light">src/data/logos.ts</code>.
      </p>

      <ElementShowcase
        title="Logo Cloud — Blur Flip"
        importAs="LogoCloudBlurFlip"
        file="components/LogoCloudBlurFlip.astro"
        usage="Logos animate in with a blur-to-focus and subtle 3D flip, staggered, when scrolled into view. They rest in grayscale and color up on hover. The premium way to open a 'trusted by' section. Scroll it into view to replay."
        code={`<LogoCloudBlurFlip />`}
      >
        <LogoCloudBlurFlip />
      </ElementShowcase>

      <ElementShowcase
        title="Logo Cloud — Spotlight"
        importAs="LogoCloudSpotlight"
        file="components/LogoCloudSpotlight.astro"
        usage="Grayscale logos in a grid; a soft green spotlight follows the cursor and lights up the brands underneath. Interactive and on-brand. Move your mouse across the grid."
        code={`<LogoCloudSpotlight />`}
      >
        <LogoCloudSpotlight />
      </ElementShowcase>

      <ElementShowcase
        title="Logo Cloud — Swap"
        importAs="LogoCloudSwap"
        file="components/LogoCloudSwap.astro"
        usage="A compact row of slots that flip on a timer to cycle through all your brands — conveys 'many partners' in little space. Slots flip at staggered times. Set slots={6} to control how many show at once."
        code={`<LogoCloudSwap slots={6} />`}
      >
        <LogoCloudSwap />
      </ElementShowcase>

      <h2 data-section-heading class="mb-2 mt-4 font-display text-lg uppercase tracking-wide text-white/40">Bento Grids</h2>
      <p data-section-heading class="mb-6 max-w-2xl text-sm text-white/50">
        Three bento layouts: asymmetric photo grid, symmetric card grid, and an illustrated benefits
        grid with animated SVG art drawn in code (no images needed).
      </p>

      <ElementShowcase
        title="Bento — Photo"
